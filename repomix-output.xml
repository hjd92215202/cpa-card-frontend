<template>
  <div class="min-h-screen bg-slate-50 flex flex-col items-center p-6">
    <!-- 顶部导航 -->
    <div class="w-full max-w-4xl flex justify-between items-center mb-8">
      <el-button :icon="ArrowLeft" circle @click="router.back()" />
