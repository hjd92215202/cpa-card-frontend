<file path="src/views/admin/KnowledgeBase.vue">
<template>
  <div class="flex h-screen bg-gray-100">
    <!-- 1. 左侧学科选择 -->
    <div class="w-64 bg-white border-r flex flex-col">
      <div class="p-4 font-bold text-lg border-b flex justify-between items-center">
        <span>CPA 科目</span>
        <el-button :icon="Plus" circle size="small" @click="showAddSubject = true" />
      </div>
      <div class="flex-1 overflow-y-auto">
        <div 
          v-for="sub in subjects" :key="sub.id"
          @click="selectSubject(sub)"
          :class="['p-4 cursor-pointer hover:bg-blue-50 transition-colors border-l-4', 
                    appStore.currentSubjectId === sub.id ? 'border-blue-500 bg-blue-50 text-blue-600' : 'border-transparent']"
        >
          {{ sub.name }}
        </div>
      </div>
    </div>

    <!-- 2. 右侧章节树 -->
    <div class="flex-1 flex flex-col p-8 overflow-y-auto">
      <div v-if="appStore.currentSubjectId" class="max-w-4xl">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold">{{ appStore.currentSubjectName }} - 章节大纲</h2>
          <el-button type="primary" @click="prepareAddCategory(null)">添加根章节</el-button>
        </div>

        <el-card shadow="never">
          <el-tree
            :data="categoryTree"
            node-key="id"
            default-expand-all
            :expand-on-click-node="false"
          >
            <template #default="{ node, data }">
              <div class="flex-1 flex items-center justify-between pr-4">
                <span>{{ data.name }}</span>
                <span>
                  <el-button link type="primary" @click="prepareAddCategory(data.id)">添加子项</el-button>
                  <el-button link type="danger">删除</el-button>
                </span>
              </div>
            </template>
          </el-tree>
        </el-card>
      </div>
      
      <div v-else class="flex-1 flex flex-col items-center justify-center text-gray-400">
        <el-icon :size="64"><Notebook /></el-icon>
        <p class="mt-4">请在左侧选择一个科目开始</p>
      </div>
    </div>
  </div>

  <!-- 添加学科弹窗 -->
  <el-dialog v-model="showAddSubject" title="新增 CPA 科目" width="400px">
    <el-form :model="subjectForm" label-position="top">
      <el-form-item label="科目名称">
        <el-input v-model="subjectForm.name" placeholder="如：会计" />
      </el-form-item>
      <el-form-item label="描述">
        <el-input v-model="subjectForm.description" type="textarea" />
      </el-form-item>
    </el-form>
    <template #footer>
      <el-button @click="showAddSubject = false">取消</el-button>
      <el-button type="primary" @click="handleAddSubject">确定</el-button>
    </template>
  </el-dialog>

  <!-- 添加章节弹窗 -->
  <el-dialog v-model="showAddCategory" title="新增章节" width="400px">
    <el-form :model="categoryForm" label-position="top">
      <el-form-item label="章节名称">
        <el-input v-model="categoryForm.name" placeholder="如：第一章 长期股权投资" />
      </el-form-item>
    </el-form>
    <template #footer>
      <el-button @click="showAddCategory = false">取消</el-button>
      <el-button type="primary" @click="handleAddCategory">确定</el-button>
    </template>
  </el-dialog>
</template>

<script setup lang="ts">
import { ref, onMounted, computed } from 'vue'
import { Plus, Notebook } from '@element-plus/icons-vue'
import { subjectApi, type Subject } from '../../api/subject'
import { categoryApi, type Category } from '../../api/category'
import { useAppStore } from '../../store/appStore'
import { ElMessage } from 'element-plus'


const appStore = useAppStore()
const subjects = ref<Subject[]>([])
const categories = ref<Category[]>([])
const showAddSubject = ref(false)
const showAddCategory = ref(false)
const subjectForm = ref({ name: '', description: '', theme_color: '#1890ff' })
const categoryForm = ref({ name: '', parent_id: null as number | null })

// 加载学科
const loadSubjects = async () => {
  const res = await subjectApi.list()
  subjects.value = res as any
}

// 选择学科并加载章节
const selectSubject = async (sub: Subject) => {
  appStore.setSubject(sub.id, sub.name, sub.theme_color)
  const res = await categoryApi.listBySubject(sub.id)
  categories.value = res as any
}

// 将扁平的章节数据转换为树结构
const categoryTree = computed(() => {
  const map: any = {}
  const tree: any[] = []
  categories.value.forEach(cat => map[cat.id] = { ...cat, children: [] })
  categories.value.forEach(cat => {
    if (cat.parent_id) {
      map[cat.parent_id]?.children.push(map[cat.id])
    } else {
      tree.push(map[cat.id])
    }
  })
  return tree
})

// 新增学科
const handleAddSubject = async () => {
  if (!subjectForm.value.name) return
  await subjectApi.create(subjectForm.value)
  ElMessage.success('学科创建成功')
  showAddSubject.value = false
  loadSubjects()
}

// 准备新增章节
const prepareAddCategory = (parentId: number | null) => {
  categoryForm.value.name = ''
  categoryForm.value.parent_id = parentId
  showAddCategory.value = true
}

// 新增章节
const handleAddCategory = async () => {
  if (!categoryForm.value.name || !appStore.currentSubjectId) return
  await categoryApi.create({
    name: categoryForm.value.name,
    parent_id: categoryForm.value.parent_id,
    subject_id: appStore.currentSubjectId,
    sort_order: 0
  })
  ElMessage.success('章节创建成功')
  showAddCategory.value = false
  // 重新加载章节
  const res = await categoryApi.listBySubject(appStore.currentSubjectId)
  categories.value = res as any
}

onMounted(loadSubjects)
</script>
</file>

